{
  "name": "jsonforms-designer-root",
  "version": "0.2.1",
  "private": true,
  "description": "Modernized fork of eclipsesource/jsonforms-editor — visual editor for JSON Schema and JSON Forms UI Schema",
  "license": "MIT",
  "workspaces": [
    "packages/editor",
    "packages/app"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/app",
    "build": "npm run build --workspace=packages/editor && npm run build --workspace=packages/app",
    "build:editor": "npm run build --workspace=packages/editor",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run build && npm run test:e2e --workspace=packages/app",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.19"
  },
  "overrides": {
    "monaco-editor": {
      "dompurify": "^3.4.9"
    }
  }
}
